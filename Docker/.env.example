# =============================================================
# PDFTranslator Docker — Environment Variables
# Copy to .env and adjust values before starting
# NEVER commit the real .env to git
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=translator_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=book_translator
POSTGRES_PORT=5432

# ── CloudBeaver ───────────────────────────────────────────────
CLOUDBEAVER_PORT=8978

# ── NVIDIA NIM ────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-key-here

# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY=your-google-key-here

# ── LLM Settings ──────────────────────────────────────────────
LLM__AGENT=nvidia
LLM__NVIDIA__MODEL_NAME=meta/llama-3.1-70b-instruct
LLM__NVIDIA__TEMPERATURE=0.3
LLM__NVIDIA__TOP_P=0.95
LLM__NVIDIA__MAX_OUTPUT_TOKENS=4096

# ── Application ───────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# ── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_DEV_PORT=8000

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=80
FRONTEND_DEV_PORT=4200

# ── ELK Stack (Elasticsearch, Logstash, Filebeat, Kibana) ─────
# Elasticsearch
ELASTIC_PORT=9200
ELASTIC_HEAP_SIZE=1g
# For production with auth:
# ELASTIC_USER=elastic
# ELASTIC_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
# ELASTIC_API_KEY=

# Logstash
LOGSTASH_HEAP_SIZE=512m
LOGSTASH_PIPELINE_WORKERS=4

# Kibana
KIBANA_PORT=5601
KIBANA_HEAP_SIZE=512m

# Filebeat
FILEBEAT_REGISTRY_FILE=/var/lib/filebeat/registry/filebeat

# ── CORS (Backend) ────────────────────────────────────────────
# JSON array of origins
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:4200","http://localhost:8080"]