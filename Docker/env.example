# =============================================================
# Book Translator — Variables de Entorno
# Copiar a .env y ajustar valores antes de iniciar
# NUNCA commitear el .env real a git
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=translator_user
POSTGRES_PASSWORD=CAMBIAR_esta_clave_segura_aqui
POSTGRES_DB=book_translator
POSTGRES_PORT=5432

# ── CloudBeaver ───────────────────────────────────────────────
CLOUDBEAVER_PORT=8978

# ── NVIDIA NIM ────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ── Aplicación ────────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_LEVEL=INFO
