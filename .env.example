# =============================================================
# PDFTranslator — Environment Variables
# Copy to .env and adjust values before starting
# NEVER commit the real .env to git
# =============================================================

# ── SQLite Database ────────────────────────────────────────────
# Local development: SQLite file path (relative to project root)
DATABASE_PATH=./data/translator.db

# Docker: SQLite database path inside container
SQLITE_DB_PATH=/data/translator.db

# ── NVIDIA NIM LLM Configuration ────────────────────────────────
# Model: mistralai/mistral-large-3-675b-instruct-2512 (131k context)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL_NAME=mistralai/mistral-large-3-675b-instruct-2512
NVIDIA_MAX_OUTPUT_TOKENS=8192
NVIDIA_CONTEXT_SIZE=131072
NVIDIA_CHUNK_SAFETY_MARGIN_PCT=0.15
NVIDIA_MAX_CHUNK_TOKENS=32768
NVIDIA_MIN_CHUNK_TOKENS=512
NVIDIA_RATE_LIMIT=30
NVIDIA_TEMPERATURE=0.3
NVIDIA_TOP_P=0.95
NVIDIA_REQUEST_TIMEOUT=3600
NVIDIA_LOCAL_TOKENIZER_NAME=mistralai/Mistral-Large-3-675B-Instruct-2512
NVIDIA_LOCAL_TOKENIZER_DIR=mistral-large-3-675b-instruct-2512
# NVIDIA_EXPANSION_RATIOS=en-es=1.30,en-fr=1.25,en-de=1.30,en-zh=0.55,en-ja=0.45,en-ko=0.50

# ── Application ──────────────────────────────────────────────
APP_PORT=80
CLOUDBEAVER_PORT=8978
NLP_USE_KEYBERT=true

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:4200,http://localhost:5173,http://localhost:8080,http://10.2.1.119:4200

# ── ELK Stack (Elasticsearch, Logstash, Kibana) ──────────────
# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Logstash
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5044

# Kibana
KIBANA_URL=http://kibana:5601

# ── Optional: CloudBeaver (Database UI) ──────────────────────
# CLOUDBEAVER_PORT=8978