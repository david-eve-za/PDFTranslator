# Kong Gateway Environment Configuration
# Copy to .env and customize for your environment

# =================== KONG SETTINGS ===================
KONG_DATABASE=postgres
KONG_PG_HOST=kong-db
KONG_PG_PORT=5432
KONG_PG_USER=kong
KONG_PG_PASSWORD=kong
KONG_PG_DATABASE=kong

# For DB-less mode (uncomment and comment out DATABASE above):
# KONG_DATABASE=off
# KONG_DECLARATIVE_CONFIG=/kong/kong.yml

# Proxy
KONG_PROXY_LISTEN=0.0.0.0:8000
KONG_PROXY_LISTEN_SSL=0.0.0.0:8443

# Admin API
KONG_ADMIN_LISTEN=0.0.0.0:8001
KONG_ADMIN_LISTEN_SSL=0.0.0.0:8444

# Performance
KONG_NGINX_WORKER_PROCESSES=auto
KONG_NGINX_WORKER_CONNECTIONS=16384
KONG_NGINX_PROXY_LARGE_CLIENT_HEADER_BUFFERS=4 16k

# Logging
KONG_LOG_LEVEL=info
KONG_PROXY_ACCESS_LOG=/dev/stdout
KONG_PROXY_ERROR_LOG=/dev/stderr
KONG_ADMIN_ACCESS_LOG=/dev/stdout
KONG_ADMIN_ERROR_LOG=/dev/stderr

# Plugins
KONG_PLUGINS=bundled,request-transformer,response-transformer,correlation-id,prometheus,rate-limiting,ip-restriction,jwt,key-auth,acl

# =================== UPSTREAM SERVICES ===================
# These are the backend services Kong routes to
# In Docker Compose, they use service names; locally use host.docker.internal

CATALOG_SERVICE_URL=http://catalog-service:8001
GLOSSARY_SERVICE_URL=http://glossary-service:8002
TRANSLATION_SERVICE_URL=http://translation-service:8003
DOCUMENT_SERVICE_URL=http://document-service:8004
AUDIO_SERVICE_URL=http://audio-service:8005

# For local development (without Docker Compose):
# CATALOG_SERVICE_URL=http://host.docker.internal:8001
# GLOSSARY_SERVICE_URL=http://host.docker.internal:8002
# TRANSLATION_SERVICE_URL=http://host.docker.internal:8003
# DOCUMENT_SERVICE_URL=http://host.docker.internal:8004
# AUDIO_SERVICE_URL=http://host.docker.internal:8005

# =================== AUTHENTICATION KEYS ===================
# Generate secure keys: openssl rand -hex 32
FRONTEND_API_KEY=pdftranslator-frontend-local-dev-key-change-in-production
ADMIN_API_KEY=pdftranslator-admin-local-dev-key-change-in-production
WEBHOOK_API_KEY=pdftranslator-webhook-local-dev-key-change-in-production

# =================== CORS ORIGINS ===================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,http://localhost:8080,https://app.pdftranslator.app

# =================== RATE LIMITING ===================
# Global limits (requests per minute/hour)
GLOBAL_RATE_LIMIT_MINUTE=1000
GLOBAL_RATE_LIMIT_HOUR=50000

# Per-service limits
CATALOG_RATE_LIMIT_MINUTE=100
CATALOG_RATE_LIMIT_HOUR=1000
GLOSSARY_RATE_LIMIT_MINUTE=60
GLOSSARY_RATE_LIMIT_HOUR=500
TRANSLATION_RATE_LIMIT_MINUTE=30
TRANSLATION_RATE_LIMIT_HOUR=200
DOCUMENT_RATE_LIMIT_MINUTE=10
DOCUMENT_RATE_LIMIT_HOUR=50
AUDIO_RATE_LIMIT_MINUTE=5
AUDIO_RATE_LIMIT_HOUR=20

# =================== REQUEST SIZE LIMITS ===================
# Max payload size in MB
TRANSLATION_MAX_PAYLOAD=128
DOCUMENT_MAX_PAYLOAD=512
AUDIO_MAX_PAYLOAD=256

# =================== TIMEOUTS ===================
KONG_UPSTREAM_CONNECT_TIMEOUT=10000
KONG_UPSTREAM_SEND_TIMEOUT=60000
KONG_UPSTREAM_READ_TIMEOUT=60000

# =================== MONITORING ===================
PROMETHEUS_SCRAPE_INTERVAL=15s
GRAFANA_ADMIN_PASSWORD=admin

# =================== SSL/TLS (Production) ===================
# KONG_SSL_CERT_PATH=/kong/certs/kong.crt
# KONG_SSL_CERT_KEY_PATH=/kong/certs/kong.key
# KONG_CLIENT_SSL_CERT_PATH=/kong/certs/client.crt
# KONG_CLIENT_SSL_CERT_KEY_PATH=/kong/certs/client.key